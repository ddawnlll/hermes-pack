{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ddawnlll/hephaestus/schema/hypothesis.schema.json",
  "title": "Hephaestus Hypothesis Schema",
  "description": "Schema for hypothesis YAML files. Every hypothesis MUST explicitly contain relies_on (including [] when empty). FAIL propagation must be idempotent.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Schema version number.",
      "minimum": 1,
      "default": 1
    },
    "id": {
      "type": "string",
      "description": "Unique hypothesis identifier (e.g. H-001)."
    },
    "title": {
      "type": "string",
      "description": "Short human-readable hypothesis title."
    },
    "description": {
      "type": "string",
      "description": "Full hypothesis description — what we believe and why."
    },
    "family": {
      "type": "string",
      "description": "Hypothesis family for exhaustion tracking.",
      "default": ""
    },
    "relies_on": {
      "type": "array",
      "description": "Hypothesis IDs that this hypothesis depends on. When a dependency FAILs, blame propagates. MUST be explicitly set ([] when empty).",
      "items": { "type": "string" },
      "default": []
    },
    "status": {
      "type": "string",
      "description": "Current hypothesis lifecycle status.",
      "enum": ["draft", "active", "in_progress", "completed", "failed", "refuted", "cancelled"],
      "default": "draft"
    },
    "risk_level": {
      "type": "string",
      "description": "Perceived risk level of this hypothesis.",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium"
    },
    "metric_name": {
      "type": "string",
      "description": "Primary metric this hypothesis targets.",
      "default": ""
    },
    "threshold": {
      "type": ["number", "string"],
      "description": "Target threshold for the metric.",
      "default": ""
    },
    "direction": {
      "type": "string",
      "description": "Expected direction of improvement.",
      "enum": [">=", "<=", ">", "<", "==", "!="],
      "default": ">="
    },
    "provenance": {
      "type": "array",
      "description": "Provenance trail for this hypothesis.",
      "items": {
        "type": "object",
        "properties": {
          "provenance_id": {
            "type": "string",
            "description": "Reference to a provenance record."
          },
          "channel": {
            "type": "string",
            "description": "Channel that generated this hypothesis."
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 timestamp.",
            "format": "date-time"
          }
        },
        "required": ["provenance_id", "channel", "timestamp"],
        "additionalProperties": false
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 creation timestamp.",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 last update timestamp.",
      "format": "date-time"
    },
    "ttl": {
      "type": "integer",
      "description": "Time-to-live in ticks. Expired hypotheses are candidates for review.",
      "minimum": 1,
      "default": 48
    },
    "metadata": {
      "type": "object",
      "description": "Flexible metadata for extension.",
      "default": {}
    }
  },
  "required": ["id", "title", "relies_on", "status", "created_at"],
  "additionalProperties": false
}
